# Climate Insurance Engine — environment variables.
# Copy this file to .env and fill in your values. NEVER commit .env.

# Postgres database (used in Phase 3+; Supabase recommended)
DATABASE_URL=postgresql://user:password@localhost:5432/climate_insurance

# CEDA Archive credentials for UKCP18 (free registration)
# https://archive.ceda.ac.uk/
CEDA_USERNAME=
CEDA_PASSWORD=

# Supabase (Phase 3+)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local DuckDB path (Phase 1 default)
DUCKDB_PATH=climate_insurance.duckdb

# Logging
LOG_LEVEL=INFO
